{
  "name": "pttchrome",
  "version": "1.2.0",
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "base58": "^1.0.1",
    "bootstrap": "^5.0.0",
    "classnames": "^2.2.5",
    "hammerjs": "^2.0.8",
    "jquery": "^3.2.1",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/hammerjs": "^2.0.46",
    "@types/jquery": "3",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "husky": "^4.2.3",
    "jsdom": "^29.0.2",
    "lint-staged": "^10.0.8",
    "prettier": "^1.19.1",
    "rimraf": "^3.0.2",
    "typescript": "^6.0.3",
    "vite": "^5.4.19",
    "vitest": "2.1.9"
  },
  "lint-staged": {
    "*.json": [
      "prettier --write",
      "git add"
    ],
    "src/components/**/*.{js,json,css}": [
      "prettier --write",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "start": "vite",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "yarn@4.13.0"
}
